# Copy to .env and fill in. The app refuses to start if any required var is missing or malformed.

DATABASE_URL=postgres://poslatr:poslatr@localhost:5432/poslatr
REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=poslatr-dev
MINIO_SECRET_KEY=poslatr-dev-secret-change-me
MINIO_BUCKET=poslatr-media
MINIO_USE_SSL=false

# DEV ONLY key, safe to commit because it guards nothing outside local dev.
# For any real deployment generate your own: openssl rand -base64 32
VAULT_MASTER_KEY=D0lvKnjlqEmIZmQqse9tepF+WTCnWUjeqGTSO7fsyfw=
VAULT_KEY_VERSION=1
# VAULT_MASTER_KEY_PREVIOUS= # set only while a key rotation is in progress

NODE_ENV=development
